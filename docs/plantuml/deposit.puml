@startuml

actor Customer

participant "DepositController" as Controller
participant "AuthGuard" as Auth
participant "ValidationService" as Validation
participant "DepositService" as Service
participant "AccountRepository" as AccountRepo
participant "DB Transaction Manager" as DB
participant "AuditService" as Audit

Customer -> Controller: POST /deposit (amount)

Controller -> Auth: validate token
Auth --> Controller: userId

Controller -> Validation: validate request
Validation --> Controller: OK

Controller -> Service: deposit(userId, amount)

Service -> DB: BEGIN TRANSACTION

Service -> AccountRepo: lock(account)
AccountRepo --> Service: account

Service -> AccountRepo: credit(account, amount)

Service -> DB: insert transaction record

Service -> Audit: log deposit event

Service -> DB: COMMIT

Service --> Controller: success
Controller --> Customer: 200 OK

@enduml